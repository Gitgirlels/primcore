# ── Stripe Keys ──────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use sk_test_... and pk_test_... while testing locally
# Switch to sk_live_... and pk_live_... when going live

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Your Domain ──────────────────────────────────────────
# No trailing slash
# Use http://localhost:3000 while developing locally
# Change to your real URL when deployed

YOUR_DOMAIN=https://cocoacode.dev/

# ── Server Port ──────────────────────────────────────────
PORT=3000